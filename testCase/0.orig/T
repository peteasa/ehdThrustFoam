FoamFile
{
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// physical temperature -
//      plasma heating zones; spatial temperature gradients;
//      variable diffusion coefficient; variable neutral density

dimensions      [0 0 0 1 0 0 0];

// pressure at 1000m     at 281.65 Kelvin is about 89875 Pa
// pressure at sea level at 288.15 Kelvin is about 101325.0 Pa
// temperature drops about 6.5 degrees per 1000m or T = T0 - 0.0065 * height
// pressure Pref = P0 * pow(1.0 - 0.0065 * height / T0, 5.25588)
// Note the power factor 5.25588 (gM/RL) changes if the value of T0 changes by too much!
internalField   uniform 281.65;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    INLET
    {
        type            zeroGradient;
    }

    OUTLET
    {
        type            zeroGradient;
    }

    WALL
    {
        type            zeroGradient;
    }

    PELEMENT
    {
        type            zeroGradient;
    }

    NELEMENT
    {
        type            zeroGradient;
    }

    frontAndBackPlanes
    {
        type            empty;
    }
}

