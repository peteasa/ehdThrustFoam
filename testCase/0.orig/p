FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// kinematic pressure used in a incompressible-style solver to solve the momentum equation
// NOT the physical pressure that has dimensions of [1 -1 -2 0 0 0 0]
dimensions      [0 2 -2 0 0 0 0];

nBound          0.0;
internalField   uniform $nBound;

boundaryField
{
    INLET
    {
        type            zeroGradient;
    }

    OUTLET
    {
        type            entrainmentPressure;
        p0              uniform $nBound;
        value           uniform $nBound;
    }

    WALL
    {
        type            zeroGradient;
    }

    frontAndBackPlanes
    {
        type            empty;
    }

    PELEMENT
    {
        type            zeroGradient;
    }

    NELEMENT
    {
        type            zeroGradient;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

