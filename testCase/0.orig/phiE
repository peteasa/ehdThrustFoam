FoamFile
{
    format      ascii;
    class       volScalarField;
    object      phiE;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 2 -3 0 0 -1 0];

nBound          0.0;
internalField   uniform $nBound;

boundaryField
{
    INLET
    {
        type            zeroGradient;
    }

    OUTLET
    {
        type            zeroGradient;
    }

    WALL
    {
        type            zeroGradient;
    }

    NELEMENT
    {
        type            fixedValue;
        value           uniform $nBound;
    }

    PELEMENT
    {
        /*
        type            fixedValue;
        //type            mixed;
        //value           uniform 3000;
        //value           uniform 45000;
        value           uniform 7000;
        //refValue        uniform 45000;
        //refGradient     uniform 0;
        //valueFraction   uniform 0.1;
        /**/
        type            uniformFixedValue;

        uniformValue    table
        (
         ( 0 9000 )
         ( 0.000009999 9000 )
         ( 0.000010999 10100 )
         ( 0.000011000 10200 )
         ( 0.000011999 10200 )
         ( 0.000012000 10300 )
         ( 0.000012999 10300 )
         ( 0.000013000 10400 )
         ( 0.000013999 10400 )
         ( 0.000014000 10500 )
         ( 0.000014999 10500 )
         ( 0.000015000 10600 )
         ( 0.000015999 10600 )
         ( 0.000016000 10700 )
         ( 0.000016999 10700 )
         ( 0.000017000 10800 )
         ( 0.000017999 10800 )
         ( 0.000018000 10900 )
         ( 0.000018999 10900 )
         ( 0.000019000 11000 )
         ( 0.000019999 11000 )
        )
        /**/
    }

    frontAndBackPlanes
    {
        type            empty;
    }
}


