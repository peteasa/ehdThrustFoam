FoamFile
{
    format      ascii;
    class       volScalarField;
    object      phiE;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 2 -3 0 0 -1 0];

nBound          0.0;
internalField   uniform $nBound;

boundaryField
{
    INLET
    {
        type            zeroGradient;
    }

    OUTLET
    {
        type            zeroGradient;
    }

    WALL
    {
        type            zeroGradient;
    }

    NELEMENT
    {
        type            fixedValue;
        value           uniform $nBound;
    }

    PELEMENT
    {
        type            uniformFixedValue;

        uniformValue    table
        (
         ( 0 10000 )
         ( 0.000009999 10000 )
         ( 0.000010000 22000 )
        )
    }

    frontAndBackPlanes
    {
        type            empty;
    }
}


