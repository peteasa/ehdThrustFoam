FoamFile
{
    format      ascii;
    class       volScalarField;
    object      ne;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -3 0 0 0 0 0];

nBound          0.0;
internalField   uniform $nBound;

boundaryField
{
    INLET
    {
        type            zeroGradient;
    }

    OUTLET
    {
        type            zeroGradient;
    }

    WALL
    {
        type            zeroGradient;
    }

    frontAndBackPlanes
    {
        type            empty;
    }

    PELEMENT
    {
        // electrons absorbed at the front anode
        type            codedMixed;
        name            nePositivityBC;

        // create default reference values
        refValue        uniform 0;
        refGradient     uniform 0;
        valueFraction   uniform 0;

        code
        #{
        tmp<scalarField> tNeInternal = patchInternalField();
        const scalarField& neInternal = tNeInternal();

        scalarField& refVal = this->refValue();
        scalarField& refGrad = this->refGrad();
        scalarField& valFrac = this->valueFraction();

        refVal = 0.0;
        valFrac = 0.0;
        refGrad = 0.0;

        scalar nethreshold = 0.0;

        forAll(this->patch(), i)
        {
            scalar ne = neInternal[i];
            scalar before = ne;

            scalar current = this->operator[](i);
            scalar currentGrad = (ne - this->operator[](i)) * patch().deltaCoeffs()[i];

            // discourage un-physical negative densities
            ne = max(ne, 0);

            // normal gradient
            refGrad[i] = currentGrad + 0.1 * (0 - currentGrad);

            // enforced boundary value if valFrac[i] = 1
            refVal[i] = ne;

            // flux driven - Neumann like (valFrac=0) ; value driven - Dirichlet like (valFrac=1)
            // more weighted gradient if internal density is positive
            scalar safetyFactor = 0.2;
            valFrac[i] = 0.8 + safetyFactor * (neInternal[i] < nethreshold ? 1.0 : 0.0);
        }
        #};
    }

    NELEMENT
    {
        type            codedMixed;
        name            neGradientBC;

        refValue        uniform 0;
        refGradient     uniform 0;
        valueFraction   uniform 0;

        code
        #{
        const fvPatch& p = patch();

        tmp<scalarField> tNeInternal = patchInternalField();
        const scalarField& neInternal = tNeInternal();

        tmp<scalarField> tNN2pInternal =
            p.lookupPatchField<volScalarField, scalar>("nN2p").patchInternalField();
        const scalarField& nN2pInternal = tNN2pInternal();

        const vectorField& Epatch =
            p.lookupPatchField<volVectorField, vector>("E");

        scalarField& refVal = this->refValue();
        scalarField& refGrad = this->refGrad();
        scalarField& valFrac = this->valueFraction();

        refVal = 0.0;
        refGrad = 0.0;
        valFrac = 0.0;

        const dictionary& physical =
            db().lookupObject<IOdictionary>("physicalProperties");
        dimensionedScalar Te_dim(physical.lookup("Te"));

        tmp<scalarField> tmu_eInternal =
            p.lookupPatchField<volScalarField, scalar>("mu_e").patchInternalField();
        const scalarField& mu_eInternal = tmu_eInternal();

        tmp<scalarField> tmu_N2pInternal =
            p.lookupPatchField<volScalarField, scalar>("mu_N2p").patchInternalField();
        const scalarField& mu_N2pInternal = tmu_N2pInternal();

        tmp<scalarField> tDeInternal =
            p.lookupPatchField<volScalarField, scalar>("De").patchInternalField();
        const scalarField& DeInternal = tDeInternal();

        // emission coefficient 0.01 – 0.2 air discharges
        dimensionedScalar gamma_dim(physical.lookup("gamma"));
        const scalar gamma = gamma_dim.value();

        // outward normal
        vectorField nHat = p.nf();

        scalar nethreshold = 0.0;

        forAll(this->patch(), i)
        {
            scalar ne = neInternal[i];

            scalar mu_e = mu_eInternal[i];
            scalar mu_i = mu_N2pInternal[i];
            scalar De = DeInternal[i];

            scalar current = this->operator[](i);
            scalar currentGrad = (ne - this->operator[](i)) * patch().deltaCoeffs()[i];

            scalar En = (Epatch[i] & nHat[i]);

            // discourage un-physical negative densities
            ne = max(ne, 0);

            scalar ni = max(nN2pInternal[i], 0);

            // ion flux towards the boundary
            scalar Gamma_i = max(0.0, mu_i * ni * En);

            // electron flux towards the boundary
            scalar Gamma_e_in = max(0.0, -mu_e * ne * En);

            scalar Gamma_e = gamma * Gamma_i - Gamma_e_in;

            // enforced boundary value if valFrac[i] = 1
            refVal[i] = ne;

            // flux driven - Neumann like (valFrac=0) ; value driven - Dirichlet like (valFrac=1)
            // apply more fixed value Dirichlet like boundary if internal density is negative
            scalar safetyFactor = 0.15;
            valFrac[i] = 0.05 + safetyFactor * (current < nethreshold ? 1.0 : 0.0);

            // dne/dn
            scalar grad = - (Gamma_e + mu_e * ne * En) / De;

            // apply relaxation
            refGrad[i] = currentGrad + 0.1 * (grad - currentGrad);

            // discourage unphysical excitation
            if (En < 1e-6) { refGrad[i] = 0; }
            if (neInternal[i] < 0) { refGrad[i] = 0; }
            if (nN2pInternal[i] < 0) { refGrad[i] = 0; }
        }
        #};
    }
}

