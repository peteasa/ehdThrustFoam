FoamFile
{
    format      ascii;
    class       volScalarField;
    object      nuTilda;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    INLET
    {
        type            fixedValue;
        value           uniform 0;
    }

    OUTLET
    {
        type            zeroGradient;
    }

    WALL
    {
        type            zeroGradient;
    }

    PELEMENT
    {
        type            zeroGradient;
    }

    NELEMENT
    {
        type            zeroGradient;
    }

    frontAndBackPlanes
    {
        type            empty;
    }
}

