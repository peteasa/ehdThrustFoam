FoamFile
{
    format      ascii;
    class       volScalarField;
    object      rhoE;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -3 1 0 0 1 0];

internalField   uniform 0;

boundaryField
{
    INLET
    {
        type            zeroGradient;
    }

    OUTLET
    {
        type            zeroGradient;
    }

    WALL
    {
        type            zeroGradient;
    }

    PELEMENT
    {
        type            zeroGradient;
    }

    NELEMENT
    {
        type            fixedValue;
        value           uniform 1.6e-4;
    }

    frontAndBackPlanes
    {
        type            empty;
    }
}


