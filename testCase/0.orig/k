FoamFile
{
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

kInlet          5e-3;

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform $kInlet;

boundaryField
{
    INLET
    {
        type            fixedValue;
        value           uniform $kInlet;
    }

    OUTLET
    {
        type            inletOutlet;
        inletValue      uniform $kInlet;
        value           uniform $kInlet;
    }

    WALL
    {
        type            kqRWallFunction;
        value           uniform $kInlet;
    }

    PELEMENT
    {
        type              kqRWallFunction;
        value             uniform 1e-3;
        //value           $internalField;
    }
    NELEMENT
    {
        type              kqRWallFunction;
        value             uniform 1e-3;
        //value           $internalField;
    }

    frontAndBackPlanes
    {
        type            empty;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

