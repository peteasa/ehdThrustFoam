FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     ehdThrustFoam;
//application     foamRun;
//solver          incompressibleFluid;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         2.1e-2;

deltaT          5e-07;

writeControl    timeStep;

writeInterval   1000;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

// adjustTimeStep  yes;

// maxCo           1;

InfoSwitches
{
    // Set to 1 to increase detail of printed solver/run metrics
    printCoeffs          0;
}

// Defaults: dimensionSet 1; fileName 2; GAMGAgglomeration 1; level 2; lduMatrix 1; SolverPerformance 1; vtkUnstructuredReader 1;
//   SolverPerformance   0; :- switch off "smoothSolver:  Solving for" and "DICPCG:  Solving for"
DebugSwitches
{
    dimensionSet        1;
    fileName            2;
    GAMGAgglomeration   1;
    level               1;
    lduMatrix           1;
    SolverPerformance   0;
    vtkUnstructuredReader 1;
}

