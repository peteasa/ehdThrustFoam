FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-06;
        relTol          0.01;

        smoother        GaussSeidel;

        referenceCell   0;
        referenceValue  0.0;

        nPreSweeps         0;
        nPostSweeps        2;
        cacheAgglomeration on;
        agglomerator       faceAreaPair;
        nCellsInCoarsestLevel 1000;
        mergeLevels        1;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    U
    {
        solver          PBiCGStab;
        tolerance       1e-8;
        relTol          0.1;

        preconditioner  DILU;
    }

    UFinal
    {
        $U;
        relTol          0;
    }

    Phi
    {
        $p;
    }

    "(k|omega|epsilon)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
    }

    "(k|omega|epsilon)Final"
    {
        $U;
        relTol          0;
    }

    phiE
    {
        solver          PCG;
        tolerance       1e-10;
        relTol          1e-06;

        referenceCell   0;
        referenceValue  0.0;

        preconditioner  DIC;
    }

    phiEFinal
    {
        $phiE;
        relTol          0;
    }

    ne
    {
        solver          smoothSolver;

        tolerance       1e-08;
        relTol          1e-06;

        smoother        symGaussSeidel;
    }

    neFinal
    {
        $ne;
        relTol          0;
    }

    nN2p
    {
        solver          smoothSolver;
        tolerance       1e-08;
        relTol          1e-06;

        smoother        symGaussSeidel;
    }

    nN2pFinal
    {
        $ne;
        relTol          0;
    }

}

// timeScheme = steadyState for a steady-state simulation; otherwise transient
timeScheme $fvSchemes!ddtSchemes/default;

PIMPLE
{
#ifeq $timeScheme steadyState
    nNonOrthogonalCorrectors 0;
    residualControl
    {
        p               1e-4;
        U               1e-4;
        "(k|omega|epsilon)" 1e-4;
    }
#else
    nPhiECorrectors       2; // specific to ehdThrustFoam: default value 2
    nCorrectors           2; // default value 2
    nNonOrthogonalCorrectors 1; // default value 0
    // consistent          yes; removed in OpenFOAM-11
    momentumPredictor   yes; // default value true
    residualControl
    {
        p               1e-5;
        U               1e-5;
        "(phiE|ne|nN2p)" 1e-5;
    }
#endif

    pRefCell        0;
    pRefValue       0;
}

potentialFlow
{
    nNonOrthogonalCorrectors 50;
}

#ifeq $timeScheme steadyState
relaxationFactors
{
    // Steady-state relaxation factors
    fields
    {
        p     0.3;
    }
    equations
    {
        U     0.5;
        "(k|omega|epsilon)" 0.7;
    }
}
#else
relaxationFactors
{
    // Transient relaxation factors
    fields
    {
        p     0.3;
    }
    equations
    {
        U               0.5;
        ne              0.3;
        nN2p            0.3;
        phiE            0.5;
    }
}
#endif

